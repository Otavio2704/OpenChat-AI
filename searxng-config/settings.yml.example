use_default_settings: true

general:
  debug: false
  instance_name: "OpenChat Search"
  privacypolicy_url: false
  donation_url: false
  contact_url: false
  enable_metrics: false

search:
  safe_search: 0
  autocomplete: ""
  default_lang: "pt-BR"
  languages:
    - "pt-BR"
    - "pt"
    - "en"
  max_page: 5
  formats:
    - html
    - json

server:
  secret_key: "GERE_COM: openssl rand -hex 32"
  limiter: false
  image_proxy: false
  http_protocol_version: "1.0"
  method: "GET"

ui:
  static_use_hash: true
  default_locale: "pt"
  query_in_title: false
  infinite_scroll: false
  center_alignment: false
  theme_args:
    simple_style: auto

engines:
  - name: google
    engine: google
    shortcut: g
    language: "pt-BR"
    region: "pt-BR"
    disabled: false

  - name: bing
    engine: bing
    shortcut: b
    language: pt
    disabled: false

  - name: duckduckgo
    engine: duckduckgo
    shortcut: d
    disabled: false

  - name: wikipedia
    engine: wikipedia
    shortcut: w
    base_url: "https://pt.wikipedia.org/"
    language: "pt"
    disabled: false

  - name: brave
    engine: brave
    shortcut: br
    disabled: false

outgoing:
  request_timeout: 10.0
  max_request_timeout: 15.0
  pool_connections: 100
  pool_maxsize: 20
